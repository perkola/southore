{
  "name": "southore",
  "version": "0.0.4",
  "private": false,
  "description": "Accessible React component library built on React Aria Components",
  "homepage": "https://github.com/perkola/southore",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/perkola/southore.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./styles": {
      "import": "./dist/index.css"
    }
  },
  "scripts": {
    "build": "tsc -b && vp build",
    "lint": "vp lint .",
    "test": "vp test run --project unit && vp test run --project visual && vp test run --project visual-dark",
    "test:unit": "vp test run --project unit",
    "test:visual": "vp test run --project visual && vp test run --project visual-dark",
    "test:update": "vp test run --project visual --project visual-dark -u",
    "test:watch": "vp test --project unit",
    "test:watch:visual": "vp test --project visual --project visual-dark",
    "test:coverage": "vp test run --project unit --coverage",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepare": "vp config"
  },
  "dependencies": {
    "lucide-react": "^0.563.0",
    "react-aria-components": "^1.15.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.2.19",
    "@storybook/addon-docs": "^10.2.19",
    "@storybook/addon-mcp": "^0.4.1",
    "@storybook/react-vite": "^10.2.19",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint-plugin-storybook": "^10.2.6",
    "playwright": "^1.58.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "storybook": "^10.2.19",
    "typescript": "~5.9.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest",
    "vitest-browser-react": "^2.0.5"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "packageManager": "npm@11.11.1"
}
