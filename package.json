{
  "name": "southore",
  "version": "0.0.5",
  "private": false,
  "description": "Accessible React component library built on React Aria Components",
  "homepage": "https://github.com/perkola/southore",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/perkola/southore.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./styles": {
      "import": "./dist/index.css"
    }
  },
  "scripts": {
    "build": "tsc -b && vp build",
    "lint": "vp lint .",
    "test": "vp test run --project unit && vp test run --project visual && vp test run --project visual-dark",
    "test:unit": "vp test run --project unit",
    "test:visual": "vp test run --project visual && vp test run --project visual-dark",
    "test:update": "vp test run --project visual --project visual-dark -u",
    "test:watch": "vp test --project unit",
    "test:watch:visual": "vp test --project visual --project visual-dark",
    "test:coverage": "vp test run --project unit --coverage",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepare": "vp config"
  },
  "dependencies": {
    "lucide-react": "^1.8.0",
    "react-aria-components": "^1.17.0"
  },
  "devDependencies": {
    "@internationalized/date": "^3.12.1",
    "@storybook/addon-a11y": "^10.2.19",
    "@storybook/addon-docs": "^10.2.19",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/react-vite": "^10.2.19",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint-plugin-storybook": "^10.2.6",
    "playwright": "^1.58.1",
    "react": "^19.2.0",
    "react-aria": "^3.47.0",
    "react-dom": "^19.2.0",
    "storybook": "^10.2.19",
    "typescript": "~5.9.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest",
    "vitest-browser-react": "^2.0.5"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  }
}
